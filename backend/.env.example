# Backend environment example
# Use this file for backend/.env

# Security
JWT_SECRET=your-super-secret-key-change-this-in-production-12345
NODE_ENV=production
PORT=5000

# CORS and cookie origin
# Local development:
FRONTEND_URL=http://localhost:5173
# Production:
FRONTEND_URL_PRODUCTION=https://app.seudominio.com

# Mercado Pago
# Get these from: https://www.mercadopago.com.br/developers/panel/credentials
MP_ACCESS_TOKEN=APP_USR-YOUR_ACCESS_TOKEN_HERE
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-YOUR_ACCESS_TOKEN_HERE
MERCADO_PAGO_PUBLIC_KEY=APP_USR-YOUR_PUBLIC_KEY_HERE
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret-here
MP_SUCCESS_URL=https://your-domain.com/sucesso
MP_FAILURE_URL=https://your-domain.com/falha
MP_PENDING_URL=https://your-domain.com/pendente
MERCADO_PAGO_WEBHOOK_URL=https://your-backend-domain.com/api/payments/webhooks

# Email
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_app

# Database
DB_HOST=localhost
DB_USER=root
# DB_PASSWORD=your_password
DB_NAME=sored
DB_PORT=3306

# Payment
PAYMENT_ACTIVATION_AMOUNT=100.00
CURRENCY=BRL
