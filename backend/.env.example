# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-12345

# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URLs (para CORS)
FRONTEND_URL=https://app.seudominio.com
FRONTEND_URL_PRODUCTION=https://app.seudominio.com


# Mercado Pago Configuration
# Obtenha suas credenciais em: https://www.mercadopago.com.br/developers/panel/credentials
