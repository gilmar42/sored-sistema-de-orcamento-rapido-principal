MERCADO_PAGO_ACCESS_TOKEN=APP_USR-YOUR_ACCESS_TOKEN_HERE
MERCADO_PAGO_PUBLIC_KEY=APP_USR-YOUR_PUBLIC_KEY_HERE
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret-here
MP_SUCCESS_URL=https://your-domain.com/sucesso

# Email Configuration (para notificações)
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_app
MP_SUCCESS_URL=https://your-domain.com/sucesso
# Webhook Configuration (usar ngrok em dev, URL real em produção)
